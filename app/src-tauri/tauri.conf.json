{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Day Monitor",
  "version": "0.1.0",
  "identifier": "com.jinkunsun.daymonitor",
  "build": {
    "beforeDevCommand": "yarn dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "yarn build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "category": "Productivity",
    "targets": ["app", "dmg"],
    "resources": {
      "../../loop_entry.py": "loop/loop_entry.py",
      "../../analyze.py": "loop/analyze.py",
      "../../capture.py": "loop/capture.py",
      "../../loop.py": "loop/loop.py",
      "../../storage.py": "loop/storage.py",
      "../../report.py": "loop/report.py"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns"
    ],
    "macOS": {
      "minimumSystemVersion": "12.0"
    }
  }
}
